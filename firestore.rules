rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SCHOOL MANAGEMENT SYSTEM - SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a centralized administrative authorization model. 
     * Access is primarily governed by an "Admin" role.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the user is a registered Admin.
     * We also explicitly whitelist the master email for initial bootstrapping.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "sundayelisha179@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingAdmin(docResource) {
      return docResource != null && isAdmin();
    }

    // --- Collection Rules ---

    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isExistingAdmin(resource);
      allow delete: if isExistingAdmin(resource);
    }

    match /staffs/{staffId} {
      allow get: if isOwner(staffId) || isAdmin();
      allow list, create: if isAdmin();
      allow update, delete: if isExistingAdmin(resource);
    }

    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin(resource);
    }

    match /students/{studentId} {
      allow get, list, create: if isAdmin();
      allow update, delete: if isExistingAdmin(resource);
    }

    match /settings/{settingId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }
  }
}
