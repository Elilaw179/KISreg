rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SCHOOL MANAGEMENT SYSTEM - SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getMasterEmail() {
      return exists(/databases/$(database)/documents/settings/auth-config) 
        ? get(/databases/$(database)/documents/settings/auth-config).data.get('masterEmail', 'sundayelisha179@gmail.com')
        : "sundayelisha179@gmail.com";
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "sundayelisha179@gmail.com" ||
        request.auth.token.email == "sunday1elisha179@gmail.com" ||
        request.auth.token.email == "kis@gmail.com" ||
        request.auth.token.email == getMasterEmail()
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() && (
        request.auth.token.email == "sundayelisha179@gmail.com" ||
        request.auth.token.email == "sunday1elisha179@gmail.com" ||
        request.auth.token.email == "kis@gmail.com" ||
        request.auth.token.email == getMasterEmail()
      );
      allow list, delete: if isAdmin();
    }

    match /staffs/{staffId} {
      allow get: if isOwner(staffId) || isAdmin();
      allow list, create, update: if isAdmin();
      allow delete: if false; 
    }

    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /students/{studentId} {
      allow get, list, create, update: if isAdmin();
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow get: if settingId == 'auth-config' || isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }
  }
}