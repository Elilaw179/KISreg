rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SCHOOL MANAGEMENT SYSTEM - SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a dynamic administrative authorization model. 
     * Access is governed by an "Admin" role which can be bootstrapped 
     * via the master email configuration.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Fetches the master email from settings to allow dynamic authorization.
     */
    function getMasterEmail() {
      // Allow checking against the dynamic configuration set by the user
      return get(/databases/$(database)/documents/settings/auth-config).data.masterEmail;
    }

    /** 
     * @description Checks if the user is a registered Admin.
     * Checks:
     * 1. If user exists in the roles_admin collection.
     * 2. If user email matches the original bootstrap email.
     * 3. If user email matches the dynamic master email set in System Security.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "sunday1elisha179@gmail.com" ||
        request.auth.token.email == getMasterEmail()
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingAdmin(docResource) {
      return docResource != null && isAdmin();
    }

    // --- Collection Rules ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      // Allow creation if the user is the master admin (to bootstrap their entry)
      allow create: if isSignedIn() && (
        request.auth.token.email == "sunday1elisha179@gmail.com" ||
        request.auth.token.email == getMasterEmail()
      );
      allow list, update, delete: if isAdmin();
    }

    match /staffs/{staffId} {
      allow get: if isOwner(staffId) || isAdmin();
      allow list, create: if isAdmin();
      allow update, delete: if isExistingAdmin(resource);
    }

    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin(resource);
    }

    match /students/{studentId} {
      allow get, list, create: if isAdmin();
      allow update, delete: if isExistingAdmin(resource);
    }

    match /settings/{settingId} {
      // Allow unauthenticated get for auth-config to facilitate dynamic login checks
      allow get: if settingId == 'auth-config' || settingId == 'school-config' || isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }
  }
}