
{
  "entities": {
    "Staff": {
      "title": "Staff",
      "type": "object",
      "description": "Represents an authorized staff member within the school system, such as an administrator.",
      "properties": {
        "id": { "type": "string" },
        "staffId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "designation": { "type": "string" },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "contactNumber": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "staffId", "status", "createdAt", "updatedAt"]
    },
    "SchoolSettings": {
      "title": "School Settings",
      "type": "object",
      "description": "Global configuration for the school instance.",
      "properties": {
        "schoolName": { "type": "string" },
        "schoolAbbr": { "type": "string" },
        "schoolAddress": { "type": "string" },
        "schoolEmail": { "type": "string" },
        "schoolPhone": { "type": "string" },
        "activeSession": { "type": "string" },
        "currentTerm": { "type": "string" },
        "twoFactorEnabled": { "type": "boolean" }
      }
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student enrolled in the school.",
      "properties": {
        "id": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "dateOfAdmission": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "classId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Withdrawn", "Graduated"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "admissionNumber", "fullName", "status", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/staffs/{staffId}": { "schema": "Staff", "description": "Staff profiles" },
    "/students/{studentId}": { "schema": "Student", "description": "Student records" },
    "/settings/{settingId}": { "schema": "SchoolSettings", "description": "Global school configurations" }
  }
}
