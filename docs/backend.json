
{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Information about a student registered at Kourrklys International School.",
      "type": "object",
      "properties": {
        "admissionNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "dateOfAdmission": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "class": { "type": "string" },
        "parentName": { "type": "string" },
        "parentContact": { "type": "string" },
        "parentEmail": { "type": "string", "format": "email" },
        "parentOccupation": { "type": "string" },
        "address": { "type": "string" },
        "previousSchool": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Withdrawn"] },
        "photoUrl": { "type": "string" },
        "nationality": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "medicalInfo": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "admissionNumber", "class", "status", "parentEmail", "parentOccupation", "parentName", "parentContact", "address"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Information about a staff member at Kourrklys International School.",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "fullName": { "type": "string" },
        "designation": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "dateOfJoining": { "type": "string", "format": "date" },
        "qualification": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dateOfBirth": { "type": "string", "format": "date" },
        "nationality": { "type": "string" },
        "maritalStatus": { "type": "string", "enum": ["Single", "Married", "Divorced", "Widowed"] },
        "address": { "type": "string" },
        "photoUrl": { "type": "string" },
        "nextOfKin": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "relationship": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name", "relationship", "phone", "address"]
        },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "staffId", "designation", "email", "phone", "department", "qualification"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "students": {
      "schema": "Student",
      "description": "Collection of student records."
    },
    "teachers": {
      "schema": "Teacher",
      "description": "Collection of staff records."
    }
  }
}
